FRYA_ENV=dev
FRYA_HOST=0.0.0.0
FRYA_PORT=8001

FRYA_DATA_DIR=./data
FRYA_RULES_DIR=./data/rules
FRYA_VERFAHRENSDOKU_DIR=./data/verfahrensdoku

FRYA_DATABASE_URL=postgresql://frya:frya@localhost:5432/frya
FRYA_REDIS_URL=redis://localhost:6379/0

FRYA_LLM_MODEL=openai/gpt-4o-mini
FRYA_OPENAI_API_KEY=
FRYA_ANTHROPIC_API_KEY=

FRYA_PAPERLESS_BASE_URL=http://localhost:8000
FRYA_PAPERLESS_TOKEN=

FRYA_AKAUNTING_BASE_URL=http://localhost:8080
FRYA_AKAUNTING_TOKEN=

FRYA_TELEGRAM_BOT_TOKEN=
FRYA_TELEGRAM_WEBHOOK_SECRET=
FRYA_TELEGRAM_DEFAULT_CHAT_ID=
FRYA_TELEGRAM_ALLOWED_CHAT_IDS=
FRYA_TELEGRAM_ALLOWED_DIRECT_CHAT_IDS=
FRYA_TELEGRAM_ALLOWED_USER_IDS=

FRYA_N8N_BASE_URL=http://localhost:5678
FRYA_N8N_TOKEN=
FRYA_N8N_DEFAULT_WORKFLOW=default-frya-workflow

# Encryption key for agent LLM API keys (Fernet, generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FRYA_CONFIG_ENCRYPTION_KEY=

# Mail provider: 'brevo' | 'mailgun' (default)
# When FRYA_MAIL_PROVIDER=brevo, system mails (password-reset, invitations) go via Brevo API v3.
# Mailgun tenant configs and the inbound webhook remain functional regardless.
FRYA_MAIL_PROVIDER=brevo
FRYA_BREVO_API_KEY=
# Sender address for system mails (reuses FRYA_MAILGUN_FROM if already set)
FRYA_MAILGUN_FROM=noreply@myfrya.de

# Mailgun (kept as fallback for tenant configs + inbound webhook)
FRYA_MAILGUN_WEBHOOK_SIGNING_KEY=
FRYA_MAILGUN_API_KEY=
FRYA_MAILGUN_DOMAIN=

# CaseEngine: default tenant for single-tenant deployments.
# Set to the UUID from frya_tenants, or leave empty to auto-detect from DB.
FRYA_DEFAULT_TENANT_ID=
