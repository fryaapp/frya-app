# Staging environment secrets – copy to staging.env and fill in real values.
# staging.env is git-ignored and must never be committed.

# Shared Postgres password (used by paperless, akaunting, n8n, and frya-agent)
STAGING_POSTGRES_PASSWORD=

# Paperless-ngx
STAGING_PAPERLESS_SECRET_KEY=
STAGING_PAPERLESS_ADMIN_PASSWORD=

# Akaunting
STAGING_AKAUNTING_ADMIN_PASSWORD=

# MariaDB (used by legacy akaunting setup if applicable)
STAGING_MARIADB_ROOT_PASSWORD=
STAGING_MARIADB_PASSWORD=

# n8n
STAGING_N8N_AUTH_PASSWORD=
STAGING_N8N_ENCRYPTION_KEY=

# Frya Agent (FRYA_ prefix is consumed by pydantic-settings)
FRYA_AUTH_SESSION_SECRET=
FRYA_AUTH_USERS_JSON=[]
FRYA_DATABASE_URL=postgresql+asyncpg://frya:STAGING_POSTGRES_PASSWORD@postgres:5432/frya
FRYA_REDIS_URL=redis://redis:6379/0
FRYA_PAPERLESS_BASE_URL=http://paperless:8000
FRYA_PAPERLESS_TOKEN=
FRYA_AKAUNTING_BASE_URL=http://akaunting:80
FRYA_AKAUNTING_TOKEN=
FRYA_LLM_MODEL=openai/gpt-4o-mini
FRYA_OPENAI_API_KEY=
FRYA_N8N_BASE_URL=http://n8n:5678
FRYA_N8N_TOKEN=
